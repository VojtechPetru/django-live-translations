msgid "demo.title"
msgstr "Live Translations Demo"

#. Greeting shown on the homepage
msgid "demo.welcome"
msgstr "Welcome to the demo application!"

msgid "demo.description"
msgstr "A minimal example app for testing django-live-translations."

msgid "about.heading"
msgstr "About this page"

msgid "about.description"
msgstr ""
"This page demonstrates the live translations widget. Log in as a superuser "
"and press Ctrl+Shift+E to activate edit mode."

msgid "how_it_works.heading"
msgstr "How it works"

msgid "edit_mode.toggle_hint %(key)s"
msgstr ""
"Press %(key)s to toggle edit mode. Translated strings will be highlighted — "
"click any one to open the editor."

msgid "features.heading"
msgstr "Features"

msgid "features.inline_editing"
msgstr "Edit translations directly in the browser"

msgid "features.instant_save"
msgstr "Changes are saved instantly without restarting the server"

msgid "common.language"
msgstr "Language"

msgid "attrs.heading"
msgstr "HTML attributes"

msgid "attrs.tooltip_trans"
msgstr "This tooltip was translated with the trans tag"

msgid "attrs.tooltip_hint"
msgstr "Hover over this paragraph to see a translated tooltip."

msgid "attrs.tooltip_context_hint"
msgstr "This paragraph has a tooltip from a context variable."

msgid "attrs.tooltip_gettext"
msgstr "This tooltip was translated with gettext()"

msgid "attrs.alt_text"
msgstr "A placeholder image demonstrating translated alt text"

msgid "attrs.alt_hint"
msgstr ""
"This image has a translated alt attribute — inspect it in your browser."

#. Inline HTML in translations
msgid "html.heading"
msgstr "Inline HTML"

msgid "html.bold_and_italic"
msgstr "Translations can contain <strong>bold</strong> and <em>italic</em> text."

msgid "html.link"
msgstr "Visit the <a href=\"https://docs.djangoproject.com\">Django docs</a> for more."

msgid "html.mixed"
msgstr "You can <strong>mix</strong> several <em>tags</em> &amp; <code>entities</code> freely."

msgid "asvar.heading"
msgstr "Variable assignment"

msgid "asvar.reused_label"
msgstr "Reusable translation"

#. Form section
msgid "form.heading"
msgstr "Django form"

msgid "form.description"
msgstr ""
"Labels and help texts below come from verbose_name / help_text — both model-"
"level and form-level."

msgid "form.feedback.verbose_name"
msgstr "Feedback"

msgid "form.feedback.verbose_name_plural"
msgstr "Feedback entries"

#. Model field labels & help texts (via gettext_lazy on the model)
msgid "form.name.label"
msgstr "Full name"

msgid "form.name.help"
msgstr "Your first and last name."

msgid "form.name.placeholder"
msgstr "Jane Doe"

msgid "form.email.label"
msgstr "Email address"

msgid "form.email.help"
msgstr "We will never share your email."

msgid "form.message.label"
msgstr "Message"

msgid "form.message.help"
msgstr "Tell us what you think."

#. Form-only field labels & help texts (set directly on the form class)
msgid "form.subject.label"
msgstr "Subject"

msgid "form.subject.help"
msgstr "A short summary of your message."

msgid "form.subject.placeholder"
msgstr "e.g. Bug report, Feature request…"

msgid "form.newsletter.label"
msgstr "Subscribe to newsletter"

msgid "form.newsletter.help"
msgstr "Receive occasional updates by email."

#. Form tabs
msgid "form.tab.manual"
msgstr "Manual rendering"

msgid "form.tab.auto"
msgstr "Auto rendering"

msgid "form.auto_description"
msgstr ""
"This tab uses {{ form.as_div }} to render the entire form automatically. "
"Django generates the labels and help texts from verbose_name / help_text — "
"live translations can edit these just like manually rendered fields."

#. Auth bar
msgid "auth.logged_in %(username)s"
msgstr "Logged in as %(username)s (translator)"

msgid "auth.logout"
msgstr "Log out"

msgid "auth.anonymous"
msgstr "Browsing as anonymous user"

msgid "auth.login"
msgstr "Log in as translator"
