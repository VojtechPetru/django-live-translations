msgid "demo.title"
msgstr "Demo živých překladů"

#. Greeting shown on the homepage
msgid "demo.welcome"
msgstr "Vítejte v demo aplikaci!"

msgid "demo.description"
msgstr "Minimální ukázková aplikace pro testování django-live-translations."

msgid "about.heading"
msgstr "O této stránce"

msgid "about.description"
msgstr ""
"Tato stránka demonstruje widget pro živé překlady. Přihlaste se jako "
"superuživatel a stiskněte Ctrl+Shift+E pro aktivaci režimu úprav."

msgid "how_it_works.heading"
msgstr "Jak to funguje"

msgid "edit_mode.toggle_hint %(key)s"
msgstr ""
"Stiskněte %(key)s pro přepnutí režimu úprav. Přeložené řetězce budou "
"zvýrazněny — klikněte na libovolný pro otevření editoru."

msgid "features.heading"
msgstr "Funkce"

msgid "features.inline_editing"
msgstr "Upravujte překlady přímo v prohlížeči"

msgid "features.instant_save"
msgstr "Změny se uloží okamžitě bez nutnosti restartu serveru"

msgid "common.language"
msgstr "Jazyk"

msgid "attrs.heading"
msgstr "HTML atributy"

msgid "attrs.tooltip_trans"
msgstr "Tento tooltip byl přeložen pomocí šablonového tagu trans"

msgid "attrs.tooltip_hint"
msgstr "Najeďte myší na tento odstavec pro zobrazení přeloženého tooltipu."

msgid "attrs.tooltip_context_hint"
msgstr "Tento odstavec má tooltip z kontextové proměnné."

msgid "attrs.tooltip_gettext"
msgstr "Tento tooltip byl přeložen pomocí gettext()"

msgid "attrs.alt_text"
msgstr "Zástupný obrázek demonstrujicí přeložený atribut alt"

msgid "attrs.alt_hint"
msgstr ""
"Tento obrázek má přeložený atribut alt — zkontrolujte ho v prohlížeči."

#. Inline HTML in translations
msgid "html.heading"
msgstr "Inline HTML"

msgid "html.bold_and_italic"
msgstr "Překlady mohou obsahovat <strong>tučný</strong> a <em>kurzívní</em> text."

msgid "html.link"
msgstr "Navštivte <a href=\"https://docs.djangoproject.com\">dokumentaci Djanga</a> pro více informací."

msgid "html.mixed"
msgstr "Můžete <strong>míchat</strong> různé <em>tagy</em> &amp; <code>entity</code> libovolně."

msgid "asvar.heading"
msgstr "Přiřazení do proměnné"

msgid "asvar.reused_label"
msgstr "Znovupoužitelný překlad"

#. Form section
msgid "form.heading"
msgstr "Django formulář"

msgid "form.description"
msgstr ""
"Popisky a nápovědy níže pochází z verbose_name / help_text — jak na úrovni "
"modelu, tak formuláře."

msgid "form.feedback.verbose_name"
msgstr "Zpětná vazba"

msgid "form.feedback.verbose_name_plural"
msgstr "Záznamy zpětné vazby"

#. Model field labels & help texts (via gettext_lazy on the model)
msgid "form.name.label"
msgstr "Celé jméno"

msgid "form.name.help"
msgstr "Vaše jméno a příjmení."

msgid "form.name.placeholder"
msgstr "Jan Novák"

msgid "form.email.label"
msgstr "E-mailová adresa"

msgid "form.email.help"
msgstr "Váš e-mail nikdy nesdílíme."

msgid "form.message.label"
msgstr "Zpráva"

msgid "form.message.help"
msgstr "Napište nám, co si myslíte."

#. Form-only field labels & help texts (set directly on the form class)
msgid "form.subject.label"
msgstr "Předmět"

msgid "form.subject.help"
msgstr "Krátké shrnutí vaší zprávy."

msgid "form.subject.placeholder"
msgstr "např. Hlášení chyby, Návrh funkce…"

msgid "form.newsletter.label"
msgstr "Přihlásit se k odběru novinek"

msgid "form.newsletter.help"
msgstr "Příležitostné novinky e-mailem."

#. Form tabs
msgid "form.tab.manual"
msgstr "Ruční vykreslení"

msgid "form.tab.auto"
msgstr "Automatické vykreslení"

msgid "form.auto_description"
msgstr ""
"Tato záložka používá {{ form.as_div }} k automatickému vykreslení celého "
"formuláře. Django generuje popisky a nápovědy z verbose_name / help_text — "
"živé překlady je umí upravit stejně jako ručně vykreslená pole."

#. Auth bar
#. Plural forms
msgid "plurals.heading"
msgstr "Množná čísla"

msgid "plurals.notification_one %(count)s"
msgid_plural "plurals.notification_other %(count)s"
msgstr[0] "Máte %(count)s nové oznámení."
msgstr[1] "Máte %(count)s nová oznámení."
msgstr[2] "Máte %(count)s nových oznámení."
msgstr[3] "Máte %(count)s nových oznámení."

msgid "plurals.message_one %(count)s"
msgid_plural "plurals.message_other %(count)s"
msgstr[0] "Je %(count)s nepřečtená zpráva."
msgstr[1] "Jsou %(count)s nepřečtené zprávy."
msgstr[2] "Je %(count)s nepřečtených zpráv."
msgstr[3] "Je %(count)s nepřečtených zpráv."

msgid "plurals.litre_one %(count)s"
msgid_plural "plurals.litre_other %(count)s"
msgstr[0] "Zbývá %(count)s litr."
msgstr[1] "Zbývají %(count)s litry."
msgstr[2] "Zbývá %(count)s litru."
msgstr[3] "Zbývá %(count)s litrů."

msgid "auth.logged_in %(username)s"
msgstr "Přihlášen jako %(username)s (překladatel)"

msgid "auth.logout"
msgstr "Odhlásit se"

msgid "auth.anonymous"
msgstr "Prohlížíte jako anonymní uživatel"

msgid "auth.login"
msgstr "Přihlásit se jako překladatel"
